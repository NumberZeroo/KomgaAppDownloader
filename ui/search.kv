#:import dp kivy.metrics.dp

<SearchScreen>:
    canvas.before:
        Color:
            rgba: 0.18, 0.10, 0.28, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        # Top bar ricerca
        BoxLayout:
            size_hint_y: None
            height: dp(64)
            padding: [dp(12), dp(10)]
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: 0.22, 0.13, 0.34, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                orientation: 'horizontal'
                spacing: dp(6)
                canvas.before:
                    Color:
                        rgba: 0.26, 0.16, 0.38, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]
                    Color:
                        rgba: 0.30, 0.20, 0.42, 1
                    Line:
                        rounded_rectangle: self.x, self.y, self.width, self.height, dp(10)
                        width: 1.2

                TextInput:
                    id: search_input
                    hint_text: 'Cerca fumetti o serie...'
                    hint_text_color: 0.55, 0.45, 0.70, 1
                    multiline: False
                    font_size: dp(15)
                    background_color: 0, 0, 0, 0
                    foreground_color: 0.95, 0.93, 1.0, 1
                    cursor_color: 0.95, 0.80, 0.10, 1
                    padding: [dp(4), dp(10)]
                    on_text_validate: root.do_search()

            Button:
                text: 'CERCA'
                bold: True
                size_hint_x: None
                width: dp(72)
                font_size: dp(13)
                background_color: 0, 0, 0, 0
                on_release: root.do_search()
                canvas.before:
                    Color:
                        rgba: 0.95, 0.80, 0.10, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        # Tabs
        BoxLayout:
            size_hint_y: None
            height: dp(44)
            padding: [dp(10), dp(4), dp(10), 0]
            spacing: dp(6)
            canvas.before:
                Color:
                    rgba: 0.22, 0.13, 0.34, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'LIBRI'
                font_size: dp(12)
                bold: root.current_tab == 'books'
                on_release: root.switch_tab('books')
                background_color: 0, 0, 0, 0
                color: (0.95, 0.80, 0.10, 1) if root.current_tab == 'books' else (0.65, 0.55, 0.80, 1)
                canvas.after:
                    Color:
                        rgba: (0.95, 0.80, 0.10, 1) if root.current_tab == 'books' else (0, 0, 0, 0)
                    Rectangle:
                        pos: self.x, self.y
                        size: self.width, dp(2)

            Button:
                text: 'SERIE'
                font_size: dp(12)
                bold: root.current_tab == 'series'
                on_release: root.switch_tab('series')
                background_color: 0, 0, 0, 0
                color: (0.95, 0.80, 0.10, 1) if root.current_tab == 'series' else (0.65, 0.55, 0.80, 1)
                canvas.after:
                    Color:
                        rgba: (0.95, 0.80, 0.10, 1) if root.current_tab == 'series' else (0, 0, 0, 0)
                    Rectangle:
                        pos: self.x, self.y
                        size: self.width, dp(2)

            Button:
                text: 'DOWNLOADS'
                font_size: dp(12)
                on_release: app.sm.current = 'downloads'
                background_color: 0, 0, 0, 0
                color: 0.65, 0.55, 0.80, 1
                canvas.after:
                    Color:
                        rgba: 0, 0, 0, 0
                    Rectangle:
                        pos: self.x, self.y
                        size: self.width, dp(2)

            Widget:
                size_hint_x: None
                width: dp(4)

            Label:
                text: root.status_text
                font_size: dp(11)
                color: 0.65, 0.55, 0.80, 1
                halign: 'right'
                valign: 'middle'
                size_hint_x: None
                width: dp(60)

        # Separatore
        BoxLayout:
            size_hint_y: None
            height: dp(1)
            canvas.before:
                Color:
                    rgba: 0.35, 0.22, 0.50, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        ScrollView:
            GridLayout:
                id: active_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)
                padding: dp(8)

        # Barra progresso download
        BoxLayout:
            size_hint_y: None
            height: dp(64) if root.is_downloading else 0
            opacity: 1 if root.is_downloading else 0
            orientation: 'vertical'
            padding: [dp(12), dp(6)]
            spacing: dp(4)
            canvas.before:
                Color:
                    rgba: 0.22, 0.13, 0.34, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(18)
                Label:
                    text: root.download_status
                    font_size: dp(11)
                    color: 0.75, 0.70, 0.90, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                Label:
                    text: str(root.download_progress) + '/' + str(root.download_max) + ' libri'
                    font_size: dp(11)
                    bold: True
                    color: 0.95, 0.80, 0.10, 1
                    halign: 'right'
                    valign: 'middle'
                    size_hint_x: None
                    width: dp(60)
                    text_size: self.size

            ProgressBar:
                value: root.download_progress
                max: max(root.download_max, 1)

        # Bottom bar
        BoxLayout:
            size_hint_y: None
            height: dp(52)
            padding: [dp(8), dp(6)]
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: 0.22, 0.13, 0.34, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'Scarica selezionati'
                font_size: dp(13)
                on_release: root.download_selected()
                background_color: 0, 0, 0, 0
                canvas.before:
                    Color:
                        rgba: 0.30, 0.18, 0.45, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]

            Button:
                text: 'Logout'
                font_size: dp(13)
                size_hint_x: None
                width: dp(80)
                on_release: root.logout()
                background_color: 0, 0, 0, 0
                canvas.before:
                    Color:
                        rgba: 0.50, 0.10, 0.15, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]