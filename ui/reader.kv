#:import dp kivy.metrics.dp
#:import Animation kivy.animation.Animation

<ReaderButton>:
    background_color: 0, 0, 0, 0
    background_normal: ''
    font_size: dp(13)
    bold: True
    color: 1, 1, 1, 1
    canvas.before:
        Color:
            rgba: self.back_color if self.back_color else (0.30, 0.18, 0.45, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: self.border_radius if self.border_radius else [dp(8)]

<ReaderScreen>:
    canvas.before:
        Color:
            rgba: 0.10, 0.10, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:

        # === PAGINA - zoom/pan gestiti interamente da PageViewer (Python) ===
        PageViewer:
            id: page_viewer
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}

        # === TOP BAR ===
        BoxLayout:
            id: top_bar
            pos_hint: {'top': 1}
            size_hint_y: None
            height: dp(60)
            padding: [dp(15), dp(10)]
            spacing: dp(15)
            canvas.before:
                Color:
                    rgba: 0.15, 0.10, 0.25, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.30, 0.18, 0.45, 0.5
                Line:
                    points: self.x, self.y, self.x + self.width, self.y
                    width: dp(1)

            ReaderButton:
                text: 'CHIUDI'
                size_hint_x: None
                width: dp(90)
                back_color: 0.60, 0.15, 0.20, 1
                on_release: root.close_reader()

            Label:
                text: root.book_title
                shorten: True
                shorten_from: 'right'
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                font_size: dp(16)
                bold: True
                color: 0.95, 0.95, 1, 1

            Label:
                text: f"{root.current_page} / {root.total_pages}"
                size_hint_x: None
                width: dp(70)
                font_size: dp(14)
                color: 0.75, 0.70, 0.85, 1
                bold: True

        # === BOTTOM BAR ===
        BoxLayout:
            id: bottom_bar
            orientation: 'vertical'
            pos_hint: {'y': 0}
            size_hint_y: None
            height: dp(110)
            padding: [dp(20), dp(10), dp(20), dp(15)]
            spacing: dp(5)
            canvas.before:
                Color:
                    rgba: 0.15, 0.10, 0.25, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.30, 0.18, 0.45, 0.5
                Line:
                    points: self.x, self.y + self.height, self.x + self.width, self.y + self.height
                    width: dp(1)

            # Riga slider
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                spacing: dp(15)

                Label:
                    text: "1"
                    size_hint_x: None
                    width: dp(20)
                    font_size: dp(12)
                    color: 0.6, 0.6, 0.7, 1

                Slider:
                    id: page_slider
                    min: 1
                    max: root.total_pages if root.total_pages > 0 else 1
                    value: root.current_page
                    step: 1
                    on_touch_up: if self.collide_point(*args[1].pos): root.jump_to_page(int(self.value))
                    cursor_size: (dp(20), dp(20))
                    cursor_image: ''
                    canvas.after:
                        Color:
                            rgba: 0.95, 0.80, 0.10, 1
                        Ellipse:
                            pos: self.value_pos[0] - dp(10), self.value_pos[1] - dp(10)
                            size: dp(20), dp(20)

                Label:
                    text: str(root.total_pages)
                    size_hint_x: None
                    width: dp(30)
                    font_size: dp(12)
                    color: 0.6, 0.6, 0.7, 1

            Widget:
                size_hint_y: None
                height: dp(10)

            # Riga bottoni
            BoxLayout:
                size_hint_y: None
                height: dp(45)
                spacing: dp(15)

                ReaderButton:
                    text: 'MANGA (RTL)' if root.rtl_mode else 'COMIC (LTR)'
                    back_color: (0.95, 0.80, 0.10, 1) if root.rtl_mode else (0.30, 0.18, 0.45, 1)
                    color: (0.1, 0.1, 0.1, 1) if root.rtl_mode else (1, 1, 1, 1)
                    on_release: root.toggle_rtl()

                Widget:

                ReaderButton:
                    text: 'RESET ZOOM'
                    size_hint_x: None
                    width: dp(120)
                    back_color: 0.25, 0.25, 0.30, 1
                    on_release: root.reset_zoom()
