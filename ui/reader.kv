#:import dp kivy.metrics.dp
#:import Animation kivy.animation.Animation
#:import Window kivy.core.window.Window

# Definizione di uno stile comune per i bottoni trasparenti con sfondo colorato
<ReaderButton>:
    background_color: 0, 0, 0, 0
    background_normal: ''
    font_size: dp(13)
    bold: True
    color: 1, 1, 1, 1
    canvas.before:
        Color:
            # Se back_color dovesse essere None per un istante, usa il viola di default
            rgba: self.back_color if self.back_color else (0.30, 0.18, 0.45, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: self.border_radius if self.border_radius else [dp(8)]

<ReaderScreen>:
    # Sfondo grigio scurissimo (meno stancante del nero puro)
    canvas.before:
        Color:
            rgba: 0.10, 0.10, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        id: reader_layout

        # === AREA IMMAGINE E ZOOM (SCATTER) ===
        ScatterLayout:
            id: scatter
            do_rotation: False
            # Permette lo spostamento solo se siamo zoomati
            do_translation: True if self.scale > 1.01 else False
            do_scale: True
            scale_min: 1.0
            scale_max: 5.0
            auto_bring_to_front: False
            size_hint: 1, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            # Impedisce all'immagine di "volare via" dai bordi quando zoomata
            on_transform_with_touch: root.check_bounds()

            PageViewer:
                id: page_viewer
                size_hint: 1, 1
                # L'immagine vera e propria ( AsyncImage è consigliato nel PageViewer Python )

        # === AREE DI TOCCO INVISIBILI (Tap-to-Navigate) ===
        # Queste aree intercettano i tocchi PRIMA dello scatter se non siamo zoomati
        BoxLayout:
            id: touch_areas
            orientation: 'horizontal'
            size_hint: 1, 1
            # Visibili solo se non siamo zoomati per non disturbare lo zoom/pan
            opacity: 1 if scatter.scale <= 1.01 else 0

            # Area Sinistra (25% dello schermo)
            Widget:
                size_hint_x: 0.25
                on_touch_up: if self.collide_point(*args[1].pos) and scatter.scale <= 1.01: root.on_left_tap()

            # Area Centrale (50% dello schermo - Mostra/Nascondi UI)
            Widget:
                size_hint_x: 0.50
                on_touch_up: if self.collide_point(*args[1].pos) and scatter.scale <= 1.01: root.toggle_ui()

            # Area Destra (25% dello schermo)
            Widget:
                size_hint_x: 0.25
                on_touch_up: if self.collide_point(*args[1].pos) and scatter.scale <= 1.01: root.on_right_tap()


        # === TOP BAR (Animata) ===
        BoxLayout:
            id: top_bar
            # Posizione animata: y=1 (visibile) o y=1.2 (nascosta sopra)
            pos_hint: {'top': 1}
            size_hint_y: None
            height: dp(60)
            padding: [dp(15), dp(10)]
            spacing: dp(15)
            elevation: 10
            canvas.before:
                # Sfondo scuro semi-trasparente con gradiente verso il basso
                Color:
                    rgba: 0.15, 0.10, 0.25, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                # Linea sottile decorativa in basso
                Color:
                    rgba: 0.30, 0.18, 0.45, 0.5
                Line:
                    points: self.x, self.y, self.x + self.width, self.y
                    width: dp(1)

            # Bottone Chiudi (Rosso)
            ReaderButton:
                text: 'CHIUDI'
                size_hint_x: None
                width: dp(90)
                back_color: 0.60, 0.15, 0.20, 1 # Rosso scuro
                on_release: root.close_reader()

            # Titolo Libro (Centrato e troncato se lungo)
            Label:
                text: root.book_title
                shorten: True
                shorten_from: 'right'
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                font_size: dp(16)
                bold: True
                color: 0.95, 0.95, 1, 1 # Bianco sporco

            # Contatore Pagine (Piccolo e pulito)
            Label:
                text: f"{root.current_page} / {root.total_pages}"
                size_hint_x: None
                width: dp(70)
                font_size: dp(14)
                color: 0.75, 0.70, 0.85, 1 # Viola chiaro cenere
                bold: True


        # === BOTTOM BAR (Animata con Slider) ===
        BoxLayout:
            id: bottom_bar
            orientation: 'vertical'
            # Posizione animata: y=0 (visibile) o y=-0.3 (nascosta sotto)
            pos_hint: {'y': 0}
            size_hint_y: None
            height: dp(110) # Più alta per ospitare lo slider
            padding: [dp(20), dp(10), dp(20), dp(15)]
            spacing: dp(5)
            canvas.before:
                # Sfondo scuro semi-trasparente
                Color:
                    rgba: 0.15, 0.10, 0.25, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                # Linea sottile decorativa in alto
                Color:
                    rgba: 0.30, 0.18, 0.45, 0.5
                Line:
                    points: self.x, self.y + self.height, self.x + self.width, self.y + self.height
                    width: dp(1)

            # --- Riga 1: Slider Navigazione Rapida ---
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                spacing: dp(15)

                Label:
                    text: "1"
                    size_hint_x: None
                    width: dp(20)
                    font_size: dp(12)
                    color: 0.6, 0.6, 0.7, 1

                Slider:
                    id: page_slider
                    min: 1
                    max: root.total_pages if root.total_pages > 0 else 1
                    value: root.current_page
                    step: 1
                    # Aggiorna la pagina solo alla fine del trascinamento per performance
                    on_touch_up: if self.collide_point(*args[1].pos): root.jump_to_page(int(self.value))
                    # Colori personalizzati per lo slider
                    cursor_size: (dp(20), dp(20))
                    cursor_image: '' # Rimuove l'immagine di default
                    canvas.after:
                        # Cursore personalizzato (Cerchio giallo)
                        Color:
                            rgba: 0.95, 0.80, 0.10, 1
                        Ellipse:
                            pos: self.value_pos[0] - dp(10), self.value_pos[1] - dp(10)
                            size: dp(20), dp(20)

                Label:
                    text: str(root.total_pages)
                    size_hint_x: None
                    width: dp(30)
                    font_size: dp(12)
                    color: 0.6, 0.6, 0.7, 1

            # Spaziatore flessibile
            Widget:
                size_hint_y: None
                height: dp(10)

            # --- Riga 2: Controlli e Info ---
            BoxLayout:
                size_hint_y: None
                height: dp(45)
                spacing: dp(15)

                # Bottone Modalità Lettura (Cambia colore se attivo)
                ReaderButton:
                    text: 'MODO: MANGA (RTL)' if root.rtl_mode else 'MODO: COMIC (LTR)'
                    back_color: (0.95, 0.80, 0.10, 1) if root.rtl_mode else (0.30, 0.18, 0.45, 1)
                    color: (0.1, 0.1, 0.1, 1) if root.rtl_mode else (1, 1, 1, 1)
                    on_release: root.toggle_rtl()

                # Spaziatore flessibile centrale
                Widget:

                # Bottone Reset Zoom
                ReaderButton:
                    text: 'RESET ZOOM'
                    size_hint_x: None
                    width: dp(120)
                    back_color: 0.25, 0.25, 0.30, 1 # Grigio bluastro
                    on_release: root.reset_zoom()